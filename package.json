{
  "name": "iobroker.residents",
  "version": "1.1.1",
  "description": "The ioBroker Residents adapter helps to map the presence and activity status of individual residents to their digital self. This is used to create a logical overall status of all residents and their presence or current activity at home. Residents are represented by dedicated virtual devices with different types of roomie, guest, or pet.",
  "author": {
    "name": "Julian Pawlowski",
    "email": "metres_topaz.0v@icloud.com"
  },
  "homepage": "https://github.com/jpawlowski/ioBroker.residents",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "residents",
    "roommate",
    "roomie",
    "guest",
    "pet",
    "family",
    "presence",
    "activity",
    "focus mode",
    "bedtime",
    "wakeup",
    "Bewohner",
    "Mitbewohner",
    "Gast",
    "Haustier",
    "Familie",
    "Anwesenheit",
    "Aktivität",
    "Fokus Modus",
    "Schlafenszeit",
    "Weckruf"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:jpawlowski/ioBroker.residents.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/adapter-react-v5": "^8.2.2",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@tsconfig/node18": "^18.2.6",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/proxyquire": "^1.3.31",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "proxyquire": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~6.0.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "admin/build/**",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "prepack": "npm run build",
    "verify:package": "node scripts/verify-package-contents.mjs",
    "build": "build-adapter react",
    "build:watch": "build-adapter react --watch",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server",
    "dev-server:update": "dev-server update",
    "dev-server:run": "dev-server run",
    "dev-server:watch": "dev-server watch",
    "dev-server:debug": "dev-server debug",
    "dev-server:upload": "dev-server upload",
    "dev-server:backup": "dev-server backup",
    "dev-server:setup": "dev-server setup"
  },
  "overrides": {
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "serialize-javascript": "7.0.5",
    "qs": "6.14.2",
    "esbuild": "0.25.12",
    "teeny-request": {
      "http-proxy-agent": "7.0.2"
    },
    "request": {
      "form-data": "2.5.5",
      "tough-cookie": "4.1.3"
    },
    "jsdom": {
      "tough-cookie": "4.1.3"
    }
  },
  "bugs": {
    "url": "https://github.com/jpawlowski/ioBroker.residents/issues"
  },
  "readmeFilename": "README.md"
}
